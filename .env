# Cluber Mobile — Environment Variables
# Bu dosya .gitignore'da olmalı — asla commit etme!

# Backend API base URL — fiziksel iOS cihaz için bilgisayarının yerel IP'sini kullan
# Windows'ta: ipconfig → "Kablosuz LAN bağdaştırıcısı" → IPv4 Adresi
# Örnek: EXPO_PUBLIC_API_URL=http://192.168.1.42:3000/api/v1
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# Socket.IO base URL (port dahil, /api/v1 yok!)
EXPO_PUBLIC_SOCKET_URL=http://localhost:3000
